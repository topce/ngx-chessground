{
  "name": "ngx-chessground",
  "version": "21.0.0",
  "description": "angular wrapper for ornicar/chessground",
  "scripts": {
    "tsc-lib": "tsc --project ./projects/ngx-chessground/tsconfig.lib.json",
    "tsc-app": "tsc --project ./projects/ngx-chessground-example/tsconfig.app.json",
    "ng": "ng",
    "mcp": "ng mcp",
    "start": "ng serve -o",
    "build": "ng build ngx-chessground && ng build ngx-chessground-example",
    "build:lib:prod": "ng build ngx-chessground --configuration production",
    "build:app:prod": "ng build ngx-chessground-example --configuration production",
    "test:lib": "ng test ngx-chessground --no-watch",
    "test:lib:coverage": "ng test ngx-chessground --no-watch --coverage",
    "check": "npx @biomejs/biome check ./projects ",
    "fix": "npx @biomejs/biome check --write ./projects ",
    "eslint": "ng lint ngx-chessground --format visualstudio && ng lint ngx-chessground-example --format visualstudio",
    "eslint:fix": "ng lint ngx-chessground --fix --force && ng lint ngx-chessground-example --fix --force",
    "lint": "npx @biomejs/biome lint ./projects",
    "lint:fix": "npx @biomejs/biome lint --write ./projects",
    "format": "npx @biomejs/biome format --write ./projects",
    "compodoc": "npx compodoc -p projects/ngx-chessground/tsconfig.doc.json -s -r 9090 -o",
    "deploy": "ng deploy --base-href=/ngx-chessground/",
    "update:deps": "ncu -u && ncu -u --cwd projects/ngx-chessground && npm install --force",
    "publish:lib": "npm run build:lib:prod && cd dist/ngx-chessground && npm publish",
    "download-lichess": "node scripts/download-lichess.js"
  },
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@angular/service-worker": "^21.2.1",
    "chess.js": "1.4.0",
    "chessground": "9.2.1",
    "chessops": "^0.15.0",
    "fzstd": "^0.1.1",
    "jszip": "^3.10.1",
    "snabbdom": "3.6.3",
    "stockfish.js": "^10.0.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@biomejs/biome": "2.4.6",
    "@compodoc/compodoc": "1.2.1",
    "@types/chess.js": "0.13.7",
    "@types/node": "25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-cli-ghpages": "3.0.2",
    "angular-eslint": "^21.3.0",
    "eslint": "10.0.2",
    "eslint-formatter-visualstudio": "9.0.1",
    "jsdom": "^26.1.0",
    "ng-packagr": "^21.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/topce/ngx-chessground.git"
  },
  "keywords": [
    "angular",
    "chess",
    "pgn",
    "fen",
    "chessground",
    "chess.js",
    "lichess"
  ],
  "author": "topce",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/topce/ngx-chessground/issues"
  },
  "homepage": "https://github.com/topce/ngx-chessground#readme"
}
